HOST=127.0.0.1
PORT=8787
BACKEND_PORT=8787
DEFAULT_BACKEND_PROVIDER=openai-api
AUTH_SESSION_DAYS=30
SECURE_AUTH_COOKIES=false

DATABASE_URL=postgresql://margin_chat:margin_chat@127.0.0.1:5432/margin_chat
PGHOST=127.0.0.1
PGPORT=5432
PGDATABASE=margin_chat
PGUSER=margin_chat
PGPASSWORD=margin_chat
POSTGRES_SSL=false

OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-5.4

GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-3.1-pro-preview

HUGGINGFACE_API_KEY=your_huggingface_api_key
HUGGINGFACE_MODEL=openai/gpt-oss-120b
# HF_TOKEN is also supported as the Hugging Face credential.

XAI_API_KEY=your_xai_api_key
XAI_MODEL=grok-4.20-beta-latest-non-reasoning
