HOST=127.0.0.1
PORT=8787
BACKEND_PORT=8787
DEFAULT_BACKEND_PROVIDER=openai-api
AUTH_SESSION_DAYS=30
SECURE_AUTH_COOKIES=false
APP_URL=http://127.0.0.1:5173

DATABASE_URL=postgresql://margin_chat:margin_chat@127.0.0.1:5432/margin_chat
PGHOST=127.0.0.1
PGPORT=5432
PGDATABASE=margin_chat
PGUSER=margin_chat
PGPASSWORD=margin_chat
POSTGRES_SSL=false
# Set POSTGRES_SSL=true for hosted Postgres providers such as Neon in production.

OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-5.4

GEMINI_API_KEY=your_gemini_api_key
