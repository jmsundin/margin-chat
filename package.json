{
  "name": "chatgpt-v2-workspace",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --cwd client dev",
    "dev:client": "bun run --cwd client dev",
    "dev:full": "node scripts/dev.mjs",
    "dev:server": "bun --watch server/index.mjs",
    "db:logs": "docker compose logs -f postgres",
    "db:start": "docker compose up -d postgres",
    "db:stop": "docker compose down",
    "build": "bun run --cwd client build",
    "preview": "bun run --cwd client preview",
    "start:server": "node server/index.mjs"
  },
  "dependencies": {
    "pg": "^8.20.0"
  }
}
